node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# ==========================================
# Локальні конфігурації та секрети
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
